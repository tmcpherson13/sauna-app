# Tuya IoT credentials (from your Tuya IoT Platform project)
TUYA_ACCESS_ID=your_access_id
TUYA_ACCESS_SECRET=your_access_secret
TUYA_BASE_URL=https://openapi.tuyaus.com
TUYA_HEATER_DEVICE_ID=your_heater_device_id

# App password (single shared password for you + friends)
APP_PASSWORD=choose_a_password

# Used to sign session cookies - set to any long random string
SESSION_SECRET=change_this_to_something_random
